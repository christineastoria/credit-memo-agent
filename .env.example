# Required: OpenAI API key for GPT (orchestrator + subagents)
OPENAI_API_KEY=your-openai-api-key

# Required: Perplexity API key for internet research
PERPLEXITY_API_KEY=your-perplexity-api-key

# Required: Tavily API key for web search (free tier available at tavily.com)
TAVILY_API_KEY=your-tavily-api-key

# Optional: Perplexity API key (richer citations, use instead of Tavily for production)
# PERPLEXITY_API_KEY=your-perplexity-api-key

# Required: LangSmith for tracing + sandbox calculations
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=credit-memo-agent
