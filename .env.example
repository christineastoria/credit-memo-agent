# Required: OpenAI API key for GPT (orchestrator + subagents)
OPENAI_API_KEY=your-openai-api-key

# Required: Web search (pick one)
TAVILY_API_KEY=your-tavily-api-key
# PERPLEXITY_API_KEY=your-perplexity-api-key   # richer citations, use instead of Tavily

# Optional for running the agent (falls back to local execution for calculations)
# Required for evaluations, LangGraph Studio, and tracing
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=credit-memo-agent
